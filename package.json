{
  "name": "playwright",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test-ui": "npx playwright test --ui --reporter=html",
    "test-headless": "npx playwright test --project=chromium --repeat-each=10",
    "test-headed": "npx playwright test NBS-homepage-full-test-set.spec.ts --project=chromium --headed --workers=1",
    "codegen": "npx playwright codegen https://source.thenbs.com/",
    "test:twice": "npx playwright test || npx playwright test",
    "cucumber": "cucumber-js --require-module ts-node/register --require tests/step_definitions/*.ts tests/features/*.feature --parallel 1",
    "test-debug": "npx playwright test --debug"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.12.2",
    "axe-html-reporter": "^2.2.11",
    "dotenv": "^17.4.2"
  }
}
