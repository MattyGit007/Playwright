{
  "name": "playwright",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test-ui": "npx playwright test --ui --reporter=html",
    "test-headless": "npx playwright test --project=chromium --repeat-each=1",
    "test-headed": "npx playwright test NBS-homepage-full-test-set.spec.ts --project=chromium --headed --workers=1",
    "codegen": "npx playwright codegen https://source.thenbs.com/",
    "test:twice": "npx playwright test || npx playwright test",
    "test-debug": "npx playwright test --debug",
    "test-trace": "npx playwright test --project=chromium --trace=on",
    "trace": "npx playwright show-trace",
    "test:cucumber": "npx cucumber-js --config cucumber.js",
    "cucumber:report": "node scripts/generate-report.mjs",
    "cucumber:report:trace": "node scripts/generate-report-with-trace.mjs",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepare": "husky install"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --cache"
    ]
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cucumber/cucumber": "^12.9.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.12.2",
    "allure": "^3.10.0",
    "allure-cucumberjs": "^3.9.0",
    "axe-html-reporter": "^2.2.11",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^14.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  }
}
